# ========================================
# Metrics Dashboard - Backend Environment
# ========================================

# App Settings
DEV_MODE=false
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Security (Change these in production!)
ADMIN_PASSWORD=admin
JWT_SECRET=supersecretkey
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Database Config
SQLALCHEMY_DATABASE_URL=sqlite:///data/metrics.db

# Observability Infrastructure
PROMETHEUS_URL=http://prometheus:9090

# Kubernetes Integration (auto, incluster, local)
K8S_MODE=auto
# K8S_HOST=https://kubernetes.default.svc  # Only needed if K8S_MODE=local and testing remotely
